# Required for production
ADMIN_PASSWORD=your-secure-admin-password

# Storage — JSON files in GitHub repo (see STORAGE-SETUP.md)
# Vercel: github | Local dev: filesystem (default)
STORAGE_BACKEND=github
GITHUB_TOKEN=
GITHUB_REPO=vinodvin42/growing-minds-school
GITHUB_BRANCH=main
GITHUB_DATA_PREFIX=new-website/data
DATA_DIR=./data

# Do not use Vercel Blob
# BLOB_READ_WRITE_TOKEN=

# Gmail SMTP — normal sign-in passwords do NOT work; you need a Google App Password (16 chars).
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=growingmindsenglishschool@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ADMIN_EMAIL=growingmindsenglishschool@gmail.com
EMAIL_FROM_NAME=Growing Minds English School

# Optional: Resend instead of Gmail (see EMAIL-SETUP.md)
# RESEND_API_KEY=
# FROM_EMAIL=Growing Minds English School <noreply@growingmindsschool.org>
# EMAIL_PREFER=resend

# Web Push — student phone notifications (see PUSH-SETUP.md)
# Run: node scripts/generate-vapid.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:growingmindsenglishschool@gmail.com

NEXT_PUBLIC_SITE_URL=https://www.growingmindsschool.org

# Local dev only — allow /student/* in browser without installing PWA
# NEXT_PUBLIC_PWA_DEV_BYPASS=true

# Optional separate secret for student JWT sessions
# STUDENT_JWT_SECRET=
